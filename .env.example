# Admin login password (required in production)
ADMIN_PASSWORD=

# Server port (default: 3001)
PORT=3001

# Secret for signing JWT tokens (required in production; use a long random string)
JWT_SECRET=

# Allowed frontend origin for CORS and Socket.IO (default: http://localhost:5173)
FRONTEND_ORIGIN=http://localhost:5173

# Supabase (optional; if set, queue is persisted across restarts)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
# Or use service role key for backend (recommended in production):
# SUPABASE_SERVICE_ROLE_KEY=
